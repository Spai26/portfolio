---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import Tag from '../../components/ui/Tag.astro';
import { formatDate } from '../../lib/utils';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const relatedProjects = allProjects
  .filter(p => p.slug !== project.slug)
  .filter(p => p.data.stack.some(tech => project.data.stack.includes(tech)))
  .slice(0, 2);
---

<Base
  title={project.data.title}
  description={project.data.description}
>
  <article class="project-case">
    <header class="project-header">
      <div class="container">
        <a href="/projects" class="back-link">← Volver a proyectos</a>
        <div class="project-meta">
          <span class="project-year">{project.data.year}</span>
          {project.data.featured && <span class="project-badge">Destacado</span>}
        </div>
        <h1 class="project-title">{project.data.title}</h1>
        <p class="project-description">{project.data.description}</p>
        <div class="project-stack">
          {project.data.stack.map(tech => (
            <Tag label={tech} variant="accent" />
          ))}
        </div>

        <div class="project-links">
          {project.data.repoUrl && (
            <a
              href={project.data.repoUrl}
              class="project-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
              Repositorio
            </a>
          )}
          {project.data.demoUrl && (
            <a
              href={project.data.demoUrl}
              class="project-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              Demo
            </a>
          )}
        </div>
      </div>
    </header>

    <div class="project-content">
      <div class="container prose">
        <Content />
      </div>
    </div>

    {relatedProjects.length > 0 && (
      <aside class="related-projects">
        <div class="container">
          <h2 class="related-title">Proyectos relacionados</h2>
          <div class="related-grid">
            {relatedProjects.map(p => (
              <a href={`/projects/${p.slug}`} class="related-card">
                <span class="related-year">{p.data.year}</span>
                <span class="related-name">{p.data.title}</span>
              </a>
            ))}
          </div>
        </div>
      </aside>
    )}
  </article>
</Base>

<style>
  .project-header {
    padding-block: var(--space-12) var(--space-16);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-subtle);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: var(--space-6);
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .project-year {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    letter-spacing: var(--tracking-wide);
  }

  .project-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    background: var(--color-glow);
    padding: 2px 8px;
    border-radius: 3px;
  }

  .project-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-3);
    max-width: var(--content-width);
  }

  .project-description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    max-width: var(--content-width);
    line-height: var(--leading-normal);
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    transition: all var(--transition-fast);
  }

  .project-link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-glow);
  }

  .project-content {
    padding-block: var(--space-16);
  }

  .related-projects {
    padding-block: var(--space-12);
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-subtle);
  }

  .related-title {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-6);
  }

  .related-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .related-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .related-card:hover {
    border-color: var(--color-accent);
    transform: translateX(4px);
  }

  .related-year {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  .related-name {
    font-size: var(--text-sm);
    color: var(--color-text);
    font-weight: 500;
  }
</style>