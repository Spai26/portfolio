---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import ProjectCard from '../../components/ui/ProjectCard.astro';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const projects = allProjects.sort((a, b) => b.data.year - a.data.year);
---

<Base
  title="Proyectos"
  description="Proyectos de backend en producción: Clean Architecture, DDD, CQRS, PostgreSQL, Node.js. Sistemas que escalan y se mantienen."
>
  <section class="page-header">
    <div class="container">
      <h1 class="page-title">Proyectos</h1>
      <p class="page-subtitle">
        Sistemas en producción. Código que escala. Arquitectura que se mantiene.
      </p>
    </div>
  </section>

  <section class="projects-section">
    <div class="container">
      <div class="projects-grid">
        {projects.map(project => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            stack={project.data.stack}
            year={project.data.year}
            href={`/projects/${project.slug}`}
            featured={project.data.featured}
          />
        ))}
      </div>

      {projects.length === 0 && (
        <div class="empty-state">
          <p class="empty-text">No hay proyectos todavía.</p>
          <p class="empty-hint">Agregá archivos .mdx en <code>src/content/projects/</code></p>
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .page-header {
    padding-block: var(--space-16) var(--space-12);
    border-bottom: 1px solid var(--color-border);
  }

  .page-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-3);
  }

  .page-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 480px;
  }

  .projects-section {
    padding-block: var(--space-12);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-24);
  }

  .empty-text {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .empty-hint {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
  }

  .empty-hint code {
    font-size: var(--text-sm);
  }

  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>