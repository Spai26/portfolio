---
const year = new Date().getFullYear();

const footerLinks = [
  { href: 'https://github.com/sergioavalos', label: 'GitHub' },
  { href: 'https://linkedin.com/in/sergioavalos', label: 'LinkedIn' },
  { href: 'mailto:sergioai.si93@gmail.com', label: 'Email' },
];
---

<footer class="site-footer">
  <div class="container footer-content">
    <p class="footer-copy">
      <span class="text-muted">&copy; {year}</span>
      <span class="footer-name">Sergio Ávalos</span>
      <span class="text-subtle">— Backend Developer</span>
    </p>

    <nav class="footer-nav" aria-label="Footer navigation">
      {footerLinks.map(link => (
        <a
          href={link.href}
          class="footer-link"
          target={link.href.startsWith('http') ? '_blank' : undefined}
          rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-12);
    margin-top: var(--space-24);
  }

  .footer-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer-copy {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0;
  }

  .footer-name {
    font-weight: 500;
    color: var(--color-text);
  }

  .footer-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-subtle);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .footer-content {
      flex-direction: column;
      text-align: center;
    }

    .footer-copy {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>