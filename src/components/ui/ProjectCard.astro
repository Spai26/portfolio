---
import Tag from './Tag.astro';

interface Props {
  title: string;
  description: string;
  stack: string[];
  year: number;
  href: string;
  featured?: boolean;
}

const { title, description, stack, year, href, featured = false } = Astro.props;

const displayStack = stack.slice(0, 4);
const extraCount = stack.length - 4;
---

<article class:list={['project-card', { featured }]}>
  <a href={href} class="card-link" aria-label={`Ver proyecto: ${title}`}>
    <header class="card-header">
      <span class="card-year">{year}</span>
      {featured && <span class="card-badge">Destacado</span>}
    </header>

    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>

    <footer class="card-footer">
      <div class="card-tags">
        {displayStack.map(tech => (
          <Tag label={tech} />
        ))}
        {extraCount > 0 && (
          <span class="card-extra">+{extraCount}</span>
        )}
      </div>

      <span class="card-arrow" aria-hidden="true">→</span>
    </footer>
  </a>
</article>

<style>
  .project-card {
    position: relative;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: all var(--transition-fast);
  }

  .project-card:hover {
    border-color: var(--color-accent);
    background: var(--color-surface);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .project-card.featured {
    border-color: var(--color-accent);
    background: var(--color-surface);
  }

  .card-link {
    display: block;
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-3);
  }

  .card-year {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    letter-spacing: var(--tracking-wide);
  }

  .card-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    background: var(--color-glow);
    padding: 2px 8px;
    border-radius: 3px;
  }

  .card-title {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-2);
    line-height: var(--leading-tight);
  }

  .card-description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-4);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .card-extra {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  .card-arrow {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(-8px);
    transition: all var(--transition-fast);
  }

  .project-card:hover .card-arrow {
    opacity: 1;
    transform: translateX(0);
  }
</style>