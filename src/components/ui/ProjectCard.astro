---
import Tag from './Tag.astro';

interface Props {
  title: string;
  description: string;
  stack: string[];
  year: number;
  href: string;
  featured?: boolean;
  repoUrl?: string;
}

const { title, description, stack, year, href, featured = false, repoUrl } = Astro.props;

const displayStack = stack.slice(0, 4);
const extraCount = stack.length - 4;
---

<article class:list={['project-card', { featured }]}>
  <a href={href} class="card-cover-link" aria-label={`Ver proyecto: ${title}`}></a>
  <header class="card-header">
    <span class="card-year">{year}</span>
    {featured && <span class="card-badge">Destacado</span>}
  </header>

  <h3 class="card-title">{title}</h3>
  <p class="card-description">{description}</p>

  <footer class="card-footer">
    <div class="card-tags">
      {displayStack.map(tech => (
        <Tag label={tech} />
      ))}
      {extraCount > 0 && (
        <span class="card-extra">+{extraCount}</span>
      )}
    </div>

    <div class="card-actions">
      {repoUrl && (
        <a
          href={repoUrl}
          class="card-repo-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Repositorio"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
        </a>
      )}
      <span class="card-arrow" aria-hidden="true">→</span>
    </div>
  </footer>
</article>

<style>
  .project-card {
    position: relative;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-6);
    transition: all var(--transition-fast);
  }

  .project-card:hover {
    border-color: var(--color-accent);
    background: var(--color-surface);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .project-card.featured {
    border-color: var(--color-accent);
    background: var(--color-surface);
  }

  .card-cover-link {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: 8px;
  }

  .card-cover-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-3);
  }

  .card-year {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    letter-spacing: var(--tracking-wide);
  }

  .card-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    background: var(--color-glow);
    padding: 2px 8px;
    border-radius: 3px;
  }

  .card-title {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-2);
    line-height: var(--leading-tight);
  }

  .card-description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-4);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .card-extra {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  .card-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    position: relative;
    z-index: 2;
  }

  .card-repo-link {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1);
    color: var(--color-text-subtle);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    text-decoration: none;
    transition: all var(--transition-fast);
    opacity: 0;
    transform: translateX(-8px);
  }

  .project-card:hover .card-repo-link {
    opacity: 1;
    transform: translateX(0);
  }

  .card-repo-link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-glow);
  }

  .card-arrow {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(-8px);
    transition: all var(--transition-fast);
  }

  .project-card:hover .card-arrow {
    opacity: 1;
    transform: translateX(0);
  }
</style>